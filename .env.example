# ==========================================
# Server Configuration
# ==========================================
# Port on which the Express server will run
PORT=3000

# ==========================================
# Database Configuration
# ==========================================
# MongoDB Connection String. 
# IMPORTANT: Transactions (used in this project) require a MongoDB Replica Set. MongoDB Atlas provides this by default.
# How to get: 
# 1. Create a free account at https://www.mongodb.com/cloud/atlas
# 2. Build a cluster, set up database access (username/password), and whitelist your IP.
# 3. Click "Connect", choose "Connect your application", and copy the connection string.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/backend-ledger

# ==========================================
# Security Configuration
# ==========================================
# Secret key used for signing JSON Web Tokens (JWT).
# How to get: 
# You can generate a strong secure key by running this command in your terminal:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET_KEY=your_jwt_secret_key_here

# ==========================================
# Email Service Configuration (Google OAuth2 for Nodemailer)
# ==========================================
# This project uses OAuth2 to securely send emails via Nodemailer.
# How to get:
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Create a new project and enable the "Gmail API".
# 3. Go to "Credentials" -> "Create Credentials" -> "OAuth client ID" (App type: Web application).
# 4. Setup OAuth Consent screen and add your email as a test user.
# 5. Use Google OAuth2 Playground (https://developers.google.com/oauthplayground) to get the Refresh Token:
#    - Intercept scope: https://mail.google.com/
#    - Provide your Client ID and Client Secret in settings, authorize, and exchange the code for tokens.
# Full Guide: https://nodemailer.com/smtp/oauth2/#oauth-3lo

# The Gmail address associated with the OAuth credentials
EMAIL_USER=your_email@example.com

# OAuth2 Client ID from Google Cloud Console
CLIENT_ID=your_oauth2_client_id

# OAuth2 Client Secret from Google Cloud Console
CLIENT_SECRET=your_oauth2_client_secret

# OAuth2 Refresh Token from Google OAuth2 Playground
REFRESH_TOKEN=your_oauth2_refresh_token